# Health OS — deployment configuration template.
#
#   cp .env.prod.example .env.prod
#
# .env.prod is git-ignored and .docker-ignored. Fill it on the host, or feed
# these from a secret store — never commit real values.
#
# NOTE: nothing in this file is a credential you can copy. Generate your own.

# --- Database -------------------------------------------------------------
POSTGRES_USER=healthos
POSTGRES_PASSWORD=            # generate: openssl rand -base64 24
POSTGRES_DB=healthos

# Owner role. Used ONLY by the one-shot `migrate` job — schema, RLS policies,
# seed. The serving container is deliberately not given this.
DIRECT_DATABASE_URL=postgresql://healthos:CHANGE_ME@db:5432/healthos?schema=public

# Runtime role. MUST be healthos_app, which prisma/rls-roles.sql creates as
# NOSUPERUSER NOBYPASSRLS. Postgres skips every RLS policy for a role with
# either attribute, so pointing this at the owner makes tenant isolation
# silently inert — the app refuses to boot rather than serve traffic that way.
#
# The password below is the literal in prisma/rls-roles.sql. CHANGE IT on any
# host reachable by anyone but you, and change it in BOTH places:
#   ALTER ROLE healthos_app PASSWORD '<new>';
DATABASE_URL=postgresql://healthos_app:healthos_app_pw@db:5432/healthos?schema=public

# --- Application ----------------------------------------------------------
# REQUIRED, min 32 chars. The app refuses to start without it, on a known
# placeholder, or on anything shorter — a forged token defeats tenant isolation
# entirely, because RLS then faithfully enforces the tenant the ATTACKER chose.
#   openssl rand -base64 48
JWT_SECRET=

# Where the API listens on the host. Defaults to loopback only: put a TLS
# terminator in front rather than exposing the API directly. The SPA calls a
# RELATIVE /api path, so that proxy must forward /api to this service with the
# prefix stripped — the same rewrite vite.config.ts does in development.
API_BIND=127.0.0.1:3000
