# --- Secrets -----------------------------------------------------------------
# .env holds a live JWT_SECRET and the Postgres passwords. A leaked JWT secret
# lets anyone forge {tenantId: <victim>, isPlatformAdmin: true}, and the tenant
# context that drives every RLS policy is built from that token — so the secret
# is not a config wart, it is the whole isolation boundary. Commit .env.example
# instead; it ships an empty sentinel and the app refuses to boot without a real
# value (see main.ts assertJwtSecret).
.env
.env.*
# ...but the templates must ship: they are the only documentation of
# which variables exist and which are required. They contain no values.
!.env.example
!.env.prod.example
*.pem
*.key
id_rsa*
secrets/

# --- Dependencies ------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# --- Build output ------------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo

