{
  "name": "@health-os/backend",
  "version": "0.0.1",
  "description": "Health OS backend \u2014 NestJS + Prisma multi-tenant platform (Wave 0 starter)",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start:dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "check:rls": "ts-node scripts/check-rls-coverage.ts",
    "check:isolation": "ts-node scripts/check-tenant-isolation.ts",
    "check:boot": "ts-node scripts/check-boot-guards.ts",
    "check:derma-safety": "python test/safety/derma_safety_suite.py",
    "check:derma-functional": "python test/safety/derma_functional_suite.py",
    "check:dental": "python test/safety/dental_dentition_suite.py",
    "check:epi": "ts-node scripts/check-epi-schedule.ts",
    "check:epi-cold-chain": "python test/safety/epi_cold_chain_suite.py",
    "check:payroll": "python test/safety/payroll_suite.py",
    "check:clinical": "npm run check:derma-safety && npm run check:derma-functional && npm run check:dental && npm run check:epi && npm run check:epi-cold-chain && npm run check:payroll && npm run check:billing-money && npm run check:pharmacy && npm run check:lab && npm run check:ipd",
    "check:security": "npm run check:rls && npm run check:isolation && npm run check:boot",
    "check:billing-money": "python test/safety/billing_money_suite.py",
    "check:pharmacy": "python test/safety/pharmacy_safety_suite.py",
    "check:lab": "python test/safety/lab_safety_suite.py",
    "check:ipd": "python test/safety/ipd_safety_suite.py"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@prisma/client": "^5.9.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^5.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}