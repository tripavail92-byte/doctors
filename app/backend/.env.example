# PostgreSQL 16 connection string used by Prisma and the app runtime.
# The application user should be a NON-superuser so Postgres RLS policies are enforced.
# Runtime role. MUST be NOSUPERUSER and NOBYPASSRLS — a role with either
# attribute silently skips every RLS policy, making tenant isolation inert.
# Create it with prisma/rls-roles.sql.
DATABASE_URL="postgresql://healthos_app:healthos_app_pw@localhost:5432/healthos?schema=public"
# Table-owner role. Used only by prisma migrate / db push / seed.
DIRECT_DATABASE_URL="postgresql://healthos:healthos@localhost:5432/healthos?schema=public"

# Secret used to sign/verify JWT access tokens. Override in every environment.
# REQUIRED. Min 32 chars. Generate: openssl rand -base64 48
# The app refuses to boot if this is unset or a known placeholder — an
# attacker who knows the secret can forge any tenantId/isPlatformAdmin, and
# RLS would then faithfully enforce the tenant THEY chose.
JWT_SECRET=""

# HTTP port the NestJS server listens on.
PORT=3000