// ---------------------------------------------------------------------------
// Dental depth (pack.dental): periodontal charting, tooth-level plan -> billing
// glue, and the orthodontics add-on. Extends the existing ToothRecord
// odontogram. All tenant-scoped with RLS.
// ---------------------------------------------------------------------------

enum FurcationGrade {
  NONE
  I
  II
  III
}

enum DentalPlanStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrthoCaseStatus {
  PLANNED
  ACTIVE
  RETENTION
  COMPLETED
  DISCONTINUED
}

enum OrthoEventType {
  RECORDS
  BONDING
  ADJUSTMENT
  WIRE_CHANGE
  ELASTICS_CHANGE
  REPAIR
  DEBOND
  RETAINER_FIT
  RETAINER_REVIEW
}

enum ApplianceType {
  METAL_FIXED
  CERAMIC_FIXED
  SELF_LIGATING
  LINGUAL
  CLEAR_ALIGNER
  REMOVABLE
  FUNCTIONAL
  RETAINER_HAWLEY
  RETAINER_ESSIX
  RETAINER_FIXED
}

// Six-site periodontal exam. bpeSextants optional for a BPE screen (0-4 x6).
model PerioExam {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  patientId   String   @db.Uuid
  encounterId String?  @db.Uuid
  examType    String   @default("FULL") // FULL | BPE_SCREEN
  bpeSextants Int[]
  createdById String?  @db.Uuid
  createdAt   DateTime @default(now())

  tenant  Tenant             @relation(fields: [tenantId], references: [id])
  patient Patient            @relation(fields: [patientId], references: [id])
  teeth   PerioToothRecord[]

  @@index([tenantId])
  @@index([tenantId, patientId])
}

// Per-tooth six-site records. Arrays are ordered [DB, B, MB, DL, L, ML].
model PerioToothRecord {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @db.Uuid
  perioExamId String         @db.Uuid
  toothFdi    String
  pocketMm    Int[] // 6 sites, 0-15 mm
  recessionMm Int[] // 6 sites, mm from CEJ (CAL = pocket + recession)
  bleeding    Boolean[] // 6 sites
  suppuration Boolean[] // 6 sites
  plaque      Boolean[] // 6 sites
  furcation   FurcationGrade @default(NONE)
  mobility    Int? // Miller 0-3

  tenant Tenant    @relation(fields: [tenantId], references: [id])
  exam   PerioExam @relation(fields: [perioExamId], references: [id])

  @@unique([perioExamId, toothFdi])
  @@index([tenantId])
}

// Tooth-level plan line that feeds billing. Self-contained (carries catalog
// code + price) so completion can emit an InvoiceLineItem and write the
// resulting ToothRecord condition.
model ToothPlanItem {
  id                   String           @id @default(uuid()) @db.Uuid
  tenantId             String           @db.Uuid
  patientId            String           @db.Uuid
  encounterId          String?          @db.Uuid
  catalogCode          String
  name                 String
  toothFdi             String? // null for whole-mouth procedures
  surfaces             Json?
  pricePkr             Int
  status               DentalPlanStatus @default(PLANNED)
  conditionOnComplete  String? // ToothRecord condition to write on completion (e.g. FILLED)
  completedEncounterId String?          @db.Uuid
  completedAt          DateTime?
  invoiceLineItemId    String?          @db.Uuid
  createdById          String?          @db.Uuid
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@index([tenantId])
  @@index([tenantId, patientId])
}

model OrthoCase {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String          @db.Uuid
  patientId        String          @db.Uuid
  treatmentPlanId  String?         @db.Uuid
  appliance        ApplianceType
  angleClass       String?
  startDate        DateTime?
  plannedMonths    Int?
  debondDate       DateTime?
  status           OrthoCaseStatus @default(PLANNED)
  applianceMap     Json
  photoTimelineTag String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  patient Patient      @relation(fields: [patientId], references: [id])
  events  OrthoEvent[]

  @@index([tenantId])
  @@index([tenantId, patientId])
}

model OrthoEvent {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @db.Uuid
  orthoCaseId String         @db.Uuid
  encounterId String?        @db.Uuid
  eventType   OrthoEventType
  wireUpper   String?
  wireLower   String?
  elastics    String?
  note        String?
  occurredAt  DateTime       @default(now())

  tenant Tenant    @relation(fields: [tenantId], references: [id])
  case   OrthoCase @relation(fields: [orthoCaseId], references: [id])

  @@index([tenantId])
  @@index([tenantId, orthoCaseId])
}

// ---------------------------------------------------------------------------
// Ophthalmology & Optometry pack (pack.ophthalmology)
//
// Per-eye eye-exam panel (VA / refraction / IOP / segment findings) + optical
// prescription. Laterality via the shared BodySide enum (RIGHT=OD, LEFT=OS).
// IOP mirrors into the core iop_mmhg Observation (per-eye trends); VA into a
// new va_logmar metric. All tenant-scoped with RLS.
// ---------------------------------------------------------------------------

enum EyeExamStatus {
  IN_PROGRESS
  SIGNED
  AMENDED
}

enum VaCondition {
  UNAIDED
  PINHOLE
  WITH_GLASSES
  BEST_CORRECTED
}

enum VaNotation {
  SNELLEN_6
  SNELLEN_20
  LOGMAR
}

enum RefractionMethod {
  AUTOREFRACTOR
  RETINOSCOPY
  SUBJECTIVE
  CYCLOPLEGIC
}

enum IopMethod {
  GAT
  NCT
  ICARE
  PERKINS
  TONOPEN
}

enum EyeSegment {
  ANTERIOR
  POSTERIOR
}

enum EyeStructure {
  LIDS
  CONJUNCTIVA
  CORNEA
  ANTERIOR_CHAMBER
  IRIS
  PUPIL
  LENS
  VITREOUS
  DISC
  CUP_DISC_RATIO
  MACULA
  VESSELS
  PERIPHERY
}

enum EyeFindingStatus {
  NORMAL
  ABNORMAL
  NOT_EXAMINED
}

enum RxType {
  GLASSES
  CONTACT_LENS
}

enum RxStatus {
  DRAFT
  FINAL
  DISPENSED
  EXPIRED
  CANCELLED
}

model EyeExam {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @db.Uuid
  patientId      String        @db.Uuid
  encounterId    String?       @db.Uuid
  status         EyeExamStatus @default(IN_PROGRESS)
  chiefComplaint String?
  signedById     String?       @db.Uuid
  signedAt       DateTime?
  createdById    String?       @db.Uuid
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant          Tenant                @relation(fields: [tenantId], references: [id])
  patient         Patient               @relation(fields: [patientId], references: [id])
  visualAcuities  VisualAcuityMeasure[]
  refractions     Refraction[]
  iopMeasurements IopMeasurement[]
  segmentFindings EyeSegmentFinding[]
  prescriptions   OpticalPrescription[]

  @@index([tenantId])
  @@index([tenantId, patientId])
}

model VisualAcuityMeasure {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @db.Uuid
  eyeExamId      String      @db.Uuid
  laterality     BodySide
  condition      VaCondition
  notation       VaNotation
  displayValue   String
  logmarValue    Float?
  chartDistanceM Float?
  measuredAt     DateTime    @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  eyeExam EyeExam @relation(fields: [eyeExamId], references: [id])

  @@index([tenantId])
  @@index([eyeExamId])
}

model Refraction {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid
  eyeExamId     String           @db.Uuid
  laterality    BodySide
  method        RefractionMethod
  sphere        Float
  cylinder      Float?
  axis          Int?
  add           Float?
  vaAchieved    String?
  pdBinocularMm Float?
  isFinal       Boolean          @default(false)

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  eyeExam EyeExam @relation(fields: [eyeExamId], references: [id])

  @@index([tenantId])
  @@index([eyeExamId])
}

model IopMeasurement {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  eyeExamId     String    @db.Uuid
  laterality    BodySide
  valueMmHg     Float
  method        IopMethod
  measuredAt    DateTime  @default(now())
  cctMicrons    Int?
  postDilation  Boolean   @default(false)
  alertSeverity String?
  observationId String?   @db.Uuid

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  eyeExam EyeExam @relation(fields: [eyeExamId], references: [id])

  @@index([tenantId])
  @@index([eyeExamId])
}

model EyeSegmentFinding {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @db.Uuid
  eyeExamId   String           @db.Uuid
  laterality  BodySide
  segment     EyeSegment
  structure   EyeStructure
  status      EyeFindingStatus
  findingCode String?
  gradeValue  String?
  freeText    String?

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  eyeExam EyeExam @relation(fields: [eyeExamId], references: [id])

  @@unique([tenantId, eyeExamId, laterality, structure])
  @@index([tenantId])
  @@index([eyeExamId])
}

model OpticalPrescription {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @db.Uuid
  eyeExamId          String?  @db.Uuid
  patientId          String   @db.Uuid
  type               RxType
  status             RxStatus @default(DRAFT)
  odSphere           Float?
  odCylinder         Float?
  odAxis             Int?
  odAdd              Float?
  osSphere           Float?
  osCylinder         Float?
  osAxis             Int?
  osAdd              Float?
  pdBinocularMm      Float?
  lensRecommendation Json?
  validUntil         DateTime
  prescribedById     String?  @db.Uuid
  createdAt          DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  patient Patient  @relation(fields: [patientId], references: [id])
  eyeExam EyeExam? @relation(fields: [eyeExamId], references: [id])

  @@index([tenantId])
  @@index([tenantId, patientId])
}

// ---------------------------------------------------------------------------
// Physiotherapy & Rehab pack (pack.physiotherapy)
//
// Episode of care (multi-session) -> MSK assessment (+ per-joint ROM with
// deficit banding) -> treatment sessions (modality safety-gated) -> home
// exercise programme. Outcome measures reuse the shared scored-instrument
// engine (Oswestry/QuickDASH); pain (NPRS) rides the core Observation.
// ---------------------------------------------------------------------------

enum RehabEpisodeStatus {
  ACTIVE
  COMPLETED
  DISCHARGED
  DEFAULTED
}

enum RehabSessionStatus {
  PLANNED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model RehabEpisode {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @db.Uuid
  patientId       String             @db.Uuid
  diagnosis       String
  bodyRegion      String
  onsetDate       DateTime?
  startDate       DateTime           @default(now())
  status          RehabEpisodeStatus @default(ACTIVE)
  sessionsPlanned Int                @default(0)
  goals           String?
  // Comorbidity flags read by the modality-safety engine.
  safetyIntake    Json?
  dischargedAt    DateTime?
  dischargeNote   String?
  createdById     String?            @db.Uuid
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  patient     Patient                @relation(fields: [patientId], references: [id])
  assessments MskAssessment[]
  sessions    RehabSession[]
  exercises   ExercisePrescription[]

  @@index([tenantId])
  @@index([tenantId, patientId, status])
}

model MskAssessment {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  rehabEpisodeId String   @db.Uuid
  encounterId    String?  @db.Uuid
  assessedAt     DateTime @default(now())
  posture        String?
  gait           String?
  palpation      String?
  // Structured special tests: [{name, side, result}]
  specialTests   Json?
  notes          String?
  assessedById   String?  @db.Uuid

  tenant  Tenant           @relation(fields: [tenantId], references: [id])
  episode RehabEpisode     @relation(fields: [rehabEpisodeId], references: [id])
  rom     RomMeasurement[]

  @@index([tenantId])
  @@index([tenantId, rehabEpisodeId])
}

model RomMeasurement {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  mskAssessmentId String    @db.Uuid
  joint           String
  movement        String
  laterality      BodySide?
  activeDegrees   Int?
  passiveDegrees  Int?
  // Snapshot of the reference normal at measurement time.
  normalDegrees   Int
  deficitPct      Int?
  deficitBand     String?
  note            String?

  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  assessment MskAssessment @relation(fields: [mskAssessmentId], references: [id])

  @@index([tenantId])
  @@index([mskAssessmentId])
}

model RehabSession {
  id             String             @id @default(uuid()) @db.Uuid
  tenantId       String             @db.Uuid
  rehabEpisodeId String             @db.Uuid
  encounterId    String?            @db.Uuid
  sessionNumber  Int
  status         RehabSessionStatus @default(COMPLETED)
  performedAt    DateTime           @default(now())
  modalities     String[]
  // Safety hits recorded at the time of application (audit).
  safetyNotes    Json?
  painPre        Int?
  painPost       Int?
  notes          String?
  performedById  String?            @db.Uuid

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  episode RehabEpisode @relation(fields: [rehabEpisodeId], references: [id])

  @@unique([tenantId, rehabEpisodeId, sessionNumber])
  @@index([tenantId])
  @@index([tenantId, rehabEpisodeId])
}

model ExercisePrescription {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  rehabEpisodeId   String   @db.Uuid
  exerciseCode     String
  name             String
  sets             Int?
  reps             Int?
  holdSeconds      Int?
  frequencyPerWeek Int?
  progression      String?
  instructions     String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  episode RehabEpisode @relation(fields: [rehabEpisodeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, rehabEpisodeId])
}

// ---------------------------------------------------------------------------
// Dermatology pack (pack.dermatology)
//
// Grading instruments (GAGS/PASI/EASI/SCORAD/MASI/VASI) deliberately have NO
// tables of their own — they persist through ScoredInstrumentResponse, so they
// inherit the shared trends/reporting substrate. Only phototherapy and a thin
// lesion layer are genuinely new.
// ---------------------------------------------------------------------------

enum PhototherapyModality {
  NB_UVB
  BB_UVB
  PUVA
  EXCIMER
}

enum PhototherapyStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum PhototherapyBodySite {
  WHOLE_BODY
  HANDS_FEET
  SCALP
  LOCALIZED
}

model PhototherapyCourse {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  patientId String @db.Uuid

  modality   PhototherapyModality @default(NB_UVB)
  bodySite   PhototherapyBodySite @default(WHOLE_BODY)
  laterality BodySide? // for LOCALIZED sites

  // Drives the start/increment/ceiling protocol. Unknown skin type blocks start.
  fitzpatrickType Int
  indication      String
  protocolKey     String @default("NBUVB_STANDARD")

  startDoseMj  Int
  incrementPct Int  @default(15)
  maxDoseMj    Int
  medMj        Int? // measured Minimal Erythema Dose; overrides skin-type start

  // Carries the burn interlock ACROSS visits. A grade-3 hold is stored as a
  // skipped session with no deliveredAt, which every "last delivered session"
  // filter excludes — so without this the engine forgets the burn and escalates
  // above the dose that blistered the patient. Set to the burning dose on a
  // grade-3; cleared once a session is actually delivered.
  burnHoldDoseMj Int?
  burnHoldAt     DateTime?

  status    PhototherapyStatus @default(ACTIVE)
  startedAt DateTime           @default(now())
  endedAt   DateTime?

  createdById String? @db.Uuid

  tenant   Tenant                @relation(fields: [tenantId], references: [id])
  patient  Patient               @relation(fields: [patientId], references: [id])
  sessions PhototherapySession[]

  @@index([tenantId, patientId, status])
}

model PhototherapySession {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  courseId String @db.Uuid

  sessionNo   Int
  deliveredAt DateTime?

  doseMj       Int @default(0)
  // Denormalized running total, recomputed server-side — never trusted from
  // the client. A skipped session contributes 0.
  cumulativeMj Int @default(0)

  lampHours Float?
  gapDays   Int?

  // 0 none | 1 <24h pink | 2 24-48h | 3 >48h or blistering
  erythemaGrade Int     @default(0)
  burnFlag      Boolean @default(false)

  // {suggested, applied, action, ruleFired, rationale, override, overrideReason}
  doseDecision Json?

  skipped    Boolean @default(false)
  skipReason String?
  notes      String?

  deliveredById String? @db.Uuid

  tenant Tenant             @relation(fields: [tenantId], references: [id])
  course PhototherapyCourse @relation(fields: [courseId], references: [id])

  @@unique([tenantId, courseId, sessionNo])
  @@index([tenantId, courseId, deliveredAt])
}

model SkinLesion {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  patientId   String  @db.Uuid
  encounterId String? @db.Uuid

  bodyRegion String
  laterality BodySide?

  morphology    String // macule|papule|plaque|nodule|pustule|patch
  diagnosisCode String? // ICD-10 (L70.0 acne, L40.x psoriasis, L80 vitiligo)

  // Mole surveillance: {asymmetry, border, color, diameterMm, evolving}
  abcde Json?

  status String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@index([tenantId, patientId, bodyRegion])
}

// Drug dosing rules — platform-seeded, tenant-extendable.
//
// Replaces the hardcoded DRUGS record in src/dosing/drug-catalog.ts as the
// RUNTIME read path, so a clinic can correct a regimen (or add a local
// formulary entry) without a code deploy. The pure computeDose() engine is
// unchanged — this only moves where the numbers come from.
//
// STARTER DATA, NOT A FORMULARY: the seeded regimens are illustrative and must
// be validated against a maintained PMDC/DRAP formulary before clinical use.
model DoseRule {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  drugKey     String // "paracetamol"
  displayName String
  route       String  @default("oral")
  form        String? // "syrup 120 mg/5 mL"

  mgPerKgPerDay   Float
  dosesPerDay     Int
  maxSingleDoseMg Float? // absolute per-dose cap
  maxDailyDoseMg  Float? // absolute per-day cap

  minAgeMonths       Int? // rule invalid below this age
  maxWeightKgForRule Float? // switch to adult dosing above this
  roundingStepMl     Float  @default(0)

  // [{ label: "120 mg/5 mL", mgPerMl: 24 }]
  concentrations Json
  cautions       String[]
  highRisk       Boolean  @default(false) // mandatory double-check

  isBuiltin Boolean  @default(true) // platform seed vs tenant-authored
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, drugKey, route])
  @@index([tenantId])
}

enum PrescriptionStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

// The order produced when a computed dose is committed.
//
// A snapshot, deliberately: displayName/route/concentration are copied at commit
// rather than joined from DoseRule, because a rule is now tenant-editable. If a
// clinic corrects a regimen next month, the prescription must still say what was
// actually prescribed today — a medico-legal record that silently follows its
// source is not a record.
model Prescription {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  patientId   String  @db.Uuid
  encounterId String? @db.Uuid

  drugKey     String
  displayName String
  route       String

  mgPerDose          Float
  dosesPerDay        Int
  mgPerDay           Float
  volumePerDoseMl    Float?
  concentrationLabel String?

  durationDays Int?
  prn          Boolean @default(false)
  instructions String? // caregiver-language sig

  status PrescriptionStatus @default(ACTIVE)

  // The calculation that produced this order (medico-legal chain).
  doseCalculationLogId String? @db.Uuid
  prescribedById       String? @db.Uuid

  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@index([tenantId])
  @@index([tenantId, patientId])
}

enum ToothType {
  PERMANENT
  PRIMARY
  SUPERNUMERARY
}

enum FindingStatus {
  EXISTING
  PLANNED
  IN_PROGRESS
  COMPLETED
  HISTORICAL
}

// Append-only longitudinal tooth chart.
//
// ToothRecord stays as the fast "current state" projection (one row per tooth,
// upserted). This is the HISTORY: rows are never updated or deleted, and a
// correction supersedes the prior row rather than overwriting it. A dental
// chart is a medico-legal record — "tooth 36 was sound in March and carious in
// June" is the clinically meaningful fact, and an upsert-only chart destroys it.
model ToothFinding {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  patientId   String  @db.Uuid
  encounterId String? @db.Uuid

  toothFdi         String // "11".."48" permanent, "51".."85" primary
  toothType        ToothType @default(PERMANENT)
  // e.g. "mesiodens near 11" — a supernumerary has no FDI number of its own.
  supernumeraryRef String?

  surfaces  String[] // subset of MODBL; empty = whole tooth
  condition String
  status    FindingStatus @default(EXISTING)

  mobilityGrade Int? // Miller 0-3, only meaningful when condition = MOBILE

  // Derived from the quadrant digit, never accepted from the client.
  archSide BodySide?

  note String?

  // Append-only chain: null = the active tip for this tooth.
  supersededById String? @db.Uuid

  recordedById String?  @db.Uuid
  createdAt    DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@index([tenantId])
  @@index([tenantId, patientId, toothFdi])
  @@index([tenantId, encounterId])
}
